# Home Assistant
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=replace-with-a-long-lived-access-token
HOME_ASSISTANT_CAMERA_ENTITY=camera.example

# OpenClaw
OPENCLAW_URL=http://openclaw.local:8000
OPENCLAW_TOKEN=replace-with-openclaw-token
OPENCLAW_WHATSAPP_TARGET=replace-with-whatsapp-target
OPENCLAW_EVENT_ENDPOINT=/api/events/yorkie-watch
